<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true" android:drawable="@drawable/bg_button_focused" />
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/button_inactive" />
                    <corners android:radius="@dimen/corner_radius" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:startColor="@color/highlight_top"
                        android:centerColor="@android:color/transparent"
                        android:endColor="@color/shadow_bottom"
                        android:angle="270" />
                    <corners android:radius="@dimen/corner_radius" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <stroke android:width="1dp" android:color="@color/highlight_top" />
                    <corners android:radius="@dimen/corner_radius" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
