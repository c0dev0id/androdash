<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header: bookmark icon + label -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <ImageView
            android:id="@+id/dialogBookmarkIcon"
            android:layout_width="@dimen/app_icon_size"
            android:layout_height="@dimen/app_icon_size"
            android:scaleType="fitCenter"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/dialogBookmarkLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/card_padding"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_size_large"
            android:fontFamily="@font/apotek" />

    </LinearLayout>

    <TextView
        android:id="@+id/btnEditBookmark"
        android:layout_width="match_parent"
        android:layout_height="@dimen/app_card_height"
        android:background="@drawable/bg_button"
        android:gravity="center"
        android:text="Edit"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_size_small"
        android:fontFamily="@font/apotek"
        android:layout_marginBottom="@dimen/grid_spacing" />

    <TextView
        android:id="@+id/btnDeleteBookmark"
        android:layout_width="match_parent"
        android:layout_height="@dimen/app_card_height"
        android:background="@drawable/bg_button"
        android:gravity="center"
        android:text="Delete"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_size_small"
        android:fontFamily="@font/apotek"
        android:layout_marginBottom="@dimen/grid_spacing" />

    <TextView
        android:id="@+id/btnCancelBookmark"
        android:layout_width="match_parent"
        android:layout_height="@dimen/app_card_height"
        android:background="@drawable/bg_button"
        android:gravity="center"
        android:text="Cancel"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_size_small"
        android:fontFamily="@font/apotek" />

</LinearLayout>
