<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Androdash" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowFullscreen">false</item>
        <item name="android:fontFamily">@font/apotek</item>
        <item name="fontFamily">@font/apotek</item>
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="colorPrimary">@color/button_active</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_primary</item>
    </style>

    <style name="Theme.Androdash.Dialog" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:fontFamily">@font/apotek</item>
        <item name="fontFamily">@font/apotek</item>
        <item name="colorSurface">@color/surface_dark</item>
    </style>
</resources>
